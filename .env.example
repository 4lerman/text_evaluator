# ── LLM / OpenAI (optional — only needed if bypassing Prometheus/Ollama) ──────
LLM_API_KEY=your-openai-key-here
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini

# ── Embedding model ────────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large-instruct

# ── HuggingFace token (required to download gated models, e.g. e5-large) ──────
HF_TOKEN=hf_your_token_here

# ── Semantic filtering thresholds ─────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.74       # raw cosine noise floor (e5-large noise ~0.74)
Z_SCORE_THRESHOLD=0.2           # std deviations above per-sentence mean
COMPETITOR_MARGIN=0.02          # secondary values within this margin also forwarded to LLM

# ── spaCy models ───────────────────────────────────────────────────────────────
SPACY_MODEL=xx_sent_ud_sm       # multilingual sentence segmentation
POS_MODEL=en_core_web_sm        # English POS tagging
RU_POS_MODEL=ru_core_news_sm    # Russian / Kazakh POS tagging

# ── Prometheus (Ollama-based LLM evaluator) ────────────────────────────────────
PROMETHEUS_MODEL=ollama/vicgalle/prometheus-7b-v2.0
CONFIRMATION_THRESHOLD=3        # Prometheus score >= this → confirmed (1–5 scale)
PROMETHEUS_MAX_CHUNKS=5         # hard cap: chunks forwarded to Prometheus per request
                                # ~20-40s per call on CPU; 5 chunks ≈ 150-200s worst case
                                # raise safely if you have GPU acceleration (<3s/call)

# ── Timeouts (seconds) ─────────────────────────────────────────────────────────
EVALUATE_TIMEOUT_SECONDS=300
EMBEDDING_TIMEOUT_SECONDS=60
PROMETHEUS_TIMEOUT_SECONDS=120
HIGHLIGHT_TIMEOUT_SECONDS=30
PROMETHEUS_GLOBAL_CONCURRENCY=1

# ── Input limits ───────────────────────────────────────────────────────────────
MAX_TEXT_LENGTH=20000           # ~4 000 words

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your frontend URL in production.
# Default ["*"] allows all origins (fine for local dev).
# ALLOWED_ORIGINS=["https://your-domain.com"]
